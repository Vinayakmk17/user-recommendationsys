# =============================================================================
#  Project root .gitignore
#  Covers: Python (FastAPI backend + recommender), Node/Vite (React frontend)
# =============================================================================


# ---------------------------------------------------------------------------
# Python
# ---------------------------------------------------------------------------
__pycache__/
*.py[cod]
*.pyo
*.pyd
*.egg
*.egg-info/
.eggs/
dist/
build/
*.so

# ---------------------------------------------------------------------------
# Virtual environments
# ---------------------------------------------------------------------------
.venv/
venv/
env/
ENV/

# ---------------------------------------------------------------------------
# Secrets & environment variables
# ---------------------------------------------------------------------------
.env
.env.*
!.env.example

# ---------------------------------------------------------------------------
# Databases & local media uploads
# ---------------------------------------------------------------------------
*.db
*.sqlite
*.sqlite3
media/

# ---------------------------------------------------------------------------
# Testing & coverage
# ---------------------------------------------------------------------------
.pytest_cache/
.coverage
.coverage.*
htmlcov/
coverage.xml
nosetests.xml
test-results/

# ---------------------------------------------------------------------------
# Type checking / linting caches
# ---------------------------------------------------------------------------
.mypy_cache/
.ruff_cache/
.pyright/

# ---------------------------------------------------------------------------
# Node / npm
# ---------------------------------------------------------------------------
node_modules/
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*
.pnpm-store/

# ---------------------------------------------------------------------------
# Vite / frontend build output
# ---------------------------------------------------------------------------
dist/
dist-ssr/
.vite/

# ---------------------------------------------------------------------------
# IDE & editor
# ---------------------------------------------------------------------------
.vscode/
.idea/
*.suo
*.ntvs*
*.njsproj
*.sln
*.sw?
*.swp
*.swo

# ---------------------------------------------------------------------------
# OS-generated
# ---------------------------------------------------------------------------
.DS_Store
Thumbs.db
Desktop.ini
ehthumbs.db

# ---------------------------------------------------------------------------
# Logs
# ---------------------------------------------------------------------------
*.log
logs/
pids/
*.pid
*.pid.lock

# ---------------------------------------------------------------------------
# Misc
# ---------------------------------------------------------------------------
.cache/
.temp/
.tmp/
